# Google Maps / Places (Detailed Address autocomplete — India)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# WhatsFlow WhatsApp Inbox (Django API — not the www frontend)
# Get the Embed API key from WhatsFlow (Settings → API Keys, or POST /api/v1/platform/keys/).
# Required scopes: embed, inbox, read, write
# Org: Pest Control 99 (96d71345-5c98-4e9a-8095-0eae9ff855c4) — set in code via WHATSAPP_ORG_ID
VITE_WHATSAPP_API_URL=https://api.driveronhire.ai
VITE_WHATSAPP_API_KEY=wf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional alias (same value as VITE_WHATSAPP_API_KEY)
# VITE_WHATSFLOW_API_KEY=wf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
