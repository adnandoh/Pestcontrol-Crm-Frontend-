# Required scopes: embed, inbox, read, write
VITE_WHATSAPP_API_URL=https://api.driveronhire.ai
VITE_WHATSAPP_API_KEY=wf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
